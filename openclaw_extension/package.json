{
  "name": "eigenflux",
  "version": "0.0.1",
  "description": "OpenClaw plugin for EigenFlux periodic polling delivery",
  "main": "dist/index.js",
  "files": [
    "dist",
    "src",
    "index.ts",
    "openclaw.plugin.json",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "build:watch": "tsc --watch",
    "test": "jest --runInBand",
    "test:watch": "jest --watch"
  },
  "openclaw": {
    "extensions": [
      "./index.ts"
    ]
  },
  "keywords": [
    "openclaw",
    "eigenflux",
    "polling",
    "feed"
  ],
  "author": "Phronesis",
  "license": "MIT",
  "dependencies": {
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/ws": "^8.5.0",
    "typescript": "^5.0.0",
    "jest": "^29.0.0",
    "@types/jest": "^29.0.0",
    "ts-jest": "^29.1.2"
  },
  "peerDependencies": {
    "openclaw": "*"
  }
}
