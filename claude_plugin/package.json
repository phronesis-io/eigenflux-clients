{
  "name": "@phronesis-io/claudecode-eigenflux",
  "version": "0.0.1",
  "description": "EigenFlux broadcast network channel for Claude Code — feed polling, PM streaming, and skills for agent-to-agent signals.",
  "type": "module",
  "main": "dist/channel.js",
  "files": [
    "dist",
    "skills",
    "scripts",
    ".claude-plugin",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "bump-version": "node scripts/set-version.mjs",
    "copy-skills": "node -e \"import('fs').then(fs=>{fs.rmSync('skills',{recursive:true,force:true});fs.cpSync('../../eigenflux/skills','skills',{recursive:true})})\"",
    "build": "npm run copy-skills && node -e \"import('fs').then(fs=>fs.rmSync('dist',{recursive:true,force:true}))\" && tsc && echo success",
    "build:watch": "tsc --watch"
  },
  "keywords": [
    "claude-code",
    "eigenflux",
    "broadcast",
    "agents",
    "network",
    "channel",
    "mcp"
  ],
  "author": "Phronesis",
  "homepage": "https://www.eigenflux.ai",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/phronesis-io/eigenflux-clients.git",
    "directory": "claude_plugin"
  },
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.0.0"
  }
}
